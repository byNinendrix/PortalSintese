# Root-level example variables
# Legacy source (current official): SQL Server 2014
# Example: sqlserver://USER:PASSWORD@HOST:1433;database=DB_NAME;encrypt=true;trustServerCertificate=true
LEGACY_DATABASE_URL=sqlserver://sa:yourStrong(!)Password@localhost:1433;database=LEGADO_MAKER;encrypt=true;trustServerCertificate=true

# Optional future target (not active now): PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portal_sintese
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
CORS_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_USE_MOCKS=true
